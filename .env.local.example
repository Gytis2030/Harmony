# Copy this file to .env.local and fill in your values.
# Get these from your password manager "Harmony — env vars" entry.
# NEVER commit .env.local to Git.

# Supabase Postgres — use the "Pooled" connection string (pgbouncer=true)
DATABASE_URL=

# Clerk — from your Clerk dashboard > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk — custom page URLs (must match the routes in app/)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook signing secret — from Clerk dashboard > Webhooks > your endpoint
CLERK_WEBHOOK_SECRET=

# Cloudflare R2 — from your R2 API token
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=harmony-audio

# Liveblocks — from your Liveblocks project API Keys page
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=
LIVEBLOCKS_SECRET_KEY=
